node_modules/
# dist/ = Build-Output (dist.db, .exe, unpacked) ignorieren — aber die Publish-/Viewer-
# QUELLEN darin versionieren. dist/* (nicht dist/) — sonst steigt git nicht ins Verzeichnis
# und die !-Ausnahmen wirken nicht.
dist/*
!dist/publish.js
!dist/gen-htpasswd.js
!dist/viewer/
!dist/web-template/
!dist/README.md
dist/dist.db
# Viewer: gepackte .db + electron-builder-Output nicht versionieren
dist/viewer/dist/
dist/viewer/dist.db
# Web-Bundle = generierter Output MIT Secrets (.htpasswd) + Daten (data.json) -> NIE committen
dist/web/
.env
data/*.db
data/*.db-wal
data/*.db-shm
data/runs/
data/logs/
*.log

# Regenerierbare Daten-Artefakte (Crawl-/Auswertungs-Exporte)
*.csv

# Review-Reports + Snapshots (regenerierbar)
REVIEW_*.md
data/review-snapshots/
